# ── Large files — stay local, never pushed ──────────────────────────────────
*.pdf
*.PDF
PBS_Data*.xls
PBS_Data*.xlsx

# Downloaded Excel intermediates (regenerated by fetch_pbs_drug_spend.py)
data/*.xlsx
data/pbs_drug_spend_*.xlsx

# PBAC PSD folder (thousands of PDFs, ~5 GB — gitignored entirely)
data/psds/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
venv/
.venv/
env/
.env

# ── Tracked: CSV data files and the built JS bundle ─────────────────────────
# (Explicitly unignore these even if a parent pattern would exclude them)
!data/*.csv
!site_data.js

# ── Debug / scratch files ────────────────────────────────────────────────────
xls_structure.txt
*.log
download_log.txt
data/download_log.txt

# ── Build artifacts ──────────────────────────────────────────────────────────
dist/

# ── Claude Code local config ────────────────────────────────────────────────
.claude/

# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

.vercel
.env*.local
